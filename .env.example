# ─────────────────────────────────────────────────────────
# Vaishnavi Consultants — environment template
# Copy to .env.local for dev, and configure these in Vercel
# Project Settings → Environment Variables for prod.
# ─────────────────────────────────────────────────────────

# Search-engine site verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_VERIFICATION=

# Google Analytics 4 — Measurement ID (override per environment)
# Production default is hard-coded to G-G7S430DQW4; set this in Preview
# environments to point at a staging GA4 property if you have one.
NEXT_PUBLIC_GA_ID=

# Canonical site URL — override only when you switch domain
NEXT_PUBLIC_SITE_URL=

# (Optional) Transactional email / CRM endpoints used by /api/contact
# CONTACT_FORWARD_EMAIL=
# RESEND_API_KEY=
