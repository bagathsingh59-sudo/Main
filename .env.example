# ─────────────────────────────────────────────────────────
# Vaishnavi Consultants — environment template
# Copy to .env.local for dev, and configure these in Vercel
# Project Settings → Environment Variables for prod.
# ─────────────────────────────────────────────────────────

# Search-engine site verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_VERIFICATION=

# Google Analytics 4 — Measurement ID (override per environment)
# Production default is hard-coded to G-G7S430DQW4; set this in Preview
# environments to point at a staging GA4 property if you have one.
NEXT_PUBLIC_GA_ID=

# Canonical site URL — override only when you switch domain
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────
# Transactional email — Google Workspace SMTP (used by
# /api/contact and /api/book-consultation).
#
# 1. In Google Admin, add `connect` and `info` as email
#    aliases on your Workspace user (e.g. harihar@…).
#    Aliases are free and route to that user's inbox.
# 2. Enable 2-Step Verification on that account.
# 3. Generate an App Password at:
#    https://myaccount.google.com/apppasswords
#    Use the 16-character password (no spaces) as SMTP_PASS.
# ─────────────────────────────────────────────────────────

# Workspace user that authenticates SMTP (real mailbox)
SMTP_USER=harihar@vaishnaviconsultant.com
# 16-char Google App Password (NOT your regular password)
SMTP_PASS=

# Optional SMTP overrides — defaults are Gmail (smtp.gmail.com:465 TLS)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Display name + alias shown as the "From" header
MAIL_FROM_NAME=Vaishnavi Consultant
MAIL_FROM_ADDRESS=connect@vaishnaviconsultant.com

# Inbox that receives lead notifications (aliased to harihar@)
LEAD_TO=connect@vaishnaviconsultant.com

# ─────────────────────────────────────────────────────────
# Staff-approved auto-reply
#
# When set, every lead notification email gets a green
# "✓ Approve & send auto-reply" button. Click it from
# harihar@'s inbox and the lead receives a branded "thanks,
# we'll reply within 1 working day" email.
#
# Generate a random 32+ char secret, e.g.:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────
APPROVAL_SECRET=

# ─────────────────────────────────────────────────────────
# Admin dashboard (hidden /admin URL)
#
# Single-admin auth — one password protects all admin pages.
# Sessions are HMAC-signed 30-day HTTP-only cookies.
#
# 1. Pick a strong password (12+ chars, mix case/symbols).
# 2. Generate a session secret:
#      openssl rand -hex 32
# ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ─────────────────────────────────────────────────────────
# Vercel Blob — STORAGE FOR EVERYTHING ADMIN-EDITABLE
#
# Used for:
#   • Admin image uploads (logo, favicon, OG image)
#   • Admin site-settings JSON (auto-reply mode, SEO copy,
#     keywords, navigation, email templates, etc.)
#
# Why not Edge Config: Hobby tier caps a single item at ~8 KB.
# Our settings exceeded that after the keyword library bulk
# import. Blob has 1 GB free with no per-item cap.
#
# Setup:
#   In Vercel → Storage → Create Database → Blob →
#   name "vaishnavi-assets" → connect to project.
#   Vercel auto-sets BLOB_READ_WRITE_TOKEN.
# ─────────────────────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=<auto-set by Vercel when you connect Blob store>

# Optional public override of the Blob store URL — useful only
# if the BLOB_READ_WRITE_TOKEN is not present in the environment
# but settings still need to be read (e.g., Edge runtime fallbacks).
# NEXT_PUBLIC_BLOB_STORE_URL=https://<storeId>.public.blob.vercel-storage.com

# ─────────────────────────────────────────────────────────
# IndexNow — pings Bing/Yandex to re-crawl on settings save
#
# Helps SEO changes propagate within minutes instead of days.
# Generate a key:
#   openssl rand -hex 16
# The key is served at /api/indexnow-key for Bing to verify.
# ─────────────────────────────────────────────────────────
INDEXNOW_KEY=

# ─────────────────────────────────────────────────────────
# Booking page — Google Appointment Schedules URL
#
# Set this up at calendar.google.com:
#   Click any time → Appointment schedule → configure
#   45-minute slots, Mon-Fri 9:30 AM - 7:00 PM IST → save.
#   Google gives a URL like https://calendar.app.google/xxx
# Paste that URL here. Bookings will:
#   • Live on harihar@'s calendar (zero double-booking)
#   • Auto-create Google Meet links
#   • Send invites + 24h / 1h reminders automatically
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BOOKING_URL=
